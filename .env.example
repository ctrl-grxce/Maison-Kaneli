# ── Supabase (réservations) ────────────────────────────────────────────────
# URL du projet Supabase et clé publique (anon). Fournies par le dashboard Supabase.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Emails transactionnels (Resend) ────────────────────────────────────────
# Clé API Resend (https://resend.com). Sans cette clé, les réservations sont
# bien enregistrées mais aucun email n'est envoyé.
RESEND_API_KEY=

# Adresse qui reçoit les notifications de rendez-vous (email de Maison Kanali)
BOOKING_EMAIL_TO=contact@maisonkanali.fr

# Expéditeur des emails. Doit appartenir à un domaine vérifié dans Resend.
# En attendant la vérification du domaine : onboarding@resend.dev
BOOKING_EMAIL_FROM="Maison Kanali <onboarding@resend.dev>"
